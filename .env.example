# ============================================================
# SOCIAL.FLOW — Environment configuration
# Copy this file to `.env` and fill in real values.
# Never commit `.env`. In production, source these from
# Google Secret Manager and mount as Cloud Run env vars.
# ============================================================

# --- Google Cloud / Vertex AI (PREFERRED — uses GCP billing credits) ---
# When set, ALL Gemini and ADK agent calls are routed through Vertex AI
# using Application Default Credentials (gcloud auth application-default login).
# No API key needed — costs go to your GCP billing account.
GOOGLE_CLOUD_PROJECT="socialobot"
GOOGLE_CLOUD_LOCATION="us-central1"

# --- Gemini API Key (OPTIONAL fallback — AI Studio billing) ---
# Only used if you prefer per-key billing over Vertex AI.
# Leave as "MY_GEMINI_API_KEY" (or unset) to use Vertex AI instead.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- App / Deployment ---
# Public URL where this app is hosted. Used for OAuth callbacks.
APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT="3000"

# --- Firebase Admin SDK (server-side) ---
# Base64-encoded service account JSON.
# Generate: `cat serviceAccount.json | base64 -w0`
# On Cloud Run, prefer Workload Identity instead and leave this blank.
FIREBASE_SERVICE_ACCOUNT_JSON=""

# --- Session / Token Encryption ---
# 32-byte hex string used to encrypt stored OAuth tokens (AES-256-GCM).
# Generate: `openssl rand -hex 32`
TOKEN_ENCRYPTION_KEY=""
# Used by express-session for CSRF state nonces during OAuth.
SESSION_SECRET=""

# --- Meta (Instagram Graph API) ---
# Create at https://developers.facebook.com/apps
# Required scopes: instagram_basic, instagram_content_publish, pages_show_list, pages_read_engagement
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/oauth/instagram/callback"
INSTAGRAM_GRAPH_VERSION="v21.0"

# --- AI usage quotas (optional) ---
# Per-user daily caps on expensive Gemini calls. 0 = unlimited.
DAILY_NANOBANANA_LIMIT="50"
DAILY_VEO_LIMIT="10"
